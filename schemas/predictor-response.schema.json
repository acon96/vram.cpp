{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vram-cpp.local/schemas/predictor-response.schema.json",
  "title": "VRAM Predictor Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok"],
  "properties": {
    "ok": { "type": "boolean" },
    "error": { "type": "string" },
    "message": { "type": "string" },
    "detail": { "type": "string" },
    "source": { "type": "string" },
    "path": { "type": "string" },
    "resolvedUrl": { "type": "string" },
    "supportedSources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "minimumRequiredBytes": { "type": "integer" },
    "requestedBytes": { "type": "integer" },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "url": { "type": "string" },
          "start": { "type": "integer" },
          "end": { "type": "integer" },
          "headers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer" },
        "kvCount": { "type": "integer" },
        "tensorCount": { "type": "integer" },
        "bytesConsumed": { "type": "integer" },
        "tensorListTruncated": { "type": "boolean" },
        "tensors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "dimensions": {
                "type": "array",
                "items": { "type": "integer" }
              },
              "ggmlType": { "type": "integer" },
              "dataOffset": { "type": "integer" }
            }
          }
        }
      }
    },
    "fit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executedInProcess": { "type": "boolean" },
        "command": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "binary": { "type": "string" },
            "args": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "targets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fitMiB": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "targetFreeMiB": {
              "type": "array",
              "items": { "type": "integer" }
            }
          }
        },
        "overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "deviceFreeMiB": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "deviceTotalMiB": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "hostFreeMiB": { "type": "integer" }
          }
        },
        "showLogs": { "type": "boolean" },
        "recommended": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "n_ctx": { "type": "integer" },
            "n_gpu_layers": { "type": "integer" }
          }
        },
        "status": { "type": "integer" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "memoryBytes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "weights": { "type": "integer" },
            "kvCache": { "type": "integer" },
            "device": { "type": "integer" },
            "host": { "type": "integer" }
          }
        },
        "breakdown": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "totals": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "modelMiB": { "type": "integer" },
                "contextMiB": { "type": "integer" },
                "computeMiB": { "type": "integer" }
              }
            },
            "devices": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "totalMiB": { "type": "integer" },
                  "freeMiB": { "type": "integer" },
                  "modelMiB": { "type": "integer" },
                  "contextMiB": { "type": "integer" },
                  "computeMiB": { "type": "integer" },
                  "unaccountedMiB": { "type": "integer" }
                }
              }
            },
            "host": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "totalMiB": { "type": "integer" },
                "freeMiB": { "type": "integer" },
                "modelMiB": { "type": "integer" },
                "contextMiB": { "type": "integer" },
                "computeMiB": { "type": "integer" },
                "unaccountedMiB": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
