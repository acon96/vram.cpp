+static void vram_sync_fit_log(enum ggml_log_level level, const char * fmt, ...) {
+    FILE * stream = stdout;
+    if (level == GGML_LOG_LEVEL_WARN || level == GGML_LOG_LEVEL_ERROR || level == GGML_LOG_LEVEL_DEBUG) {
+        stream = stderr;
+    }
+
+    va_list args;
+    va_start(args, fmt);
+    std::vfprintf(stream, fmt, args);
+    va_end(args);
+    std::fflush(stream);
+}
