+bool common_fit_collect_memory_data(
+        const char * path_model,
+    const llama_model_params * mparams,
+    const llama_context_params * cparams,
+        ggml_log_level log_level,
+        const common_fit_memory_override * memory_override,
+        std::vector<common_fit_memory_data> & out,
+        std::vector<std::string> & device_names,
+        std::string & error,
+        bool print_memory_breakdown) {
+    std::vector<ggml_backend_dev_t> devs;
+    uint32_t hp_ngl = 0;
+    uint32_t hp_nct = 0;
+    uint32_t hp_nex = 0;
+
+    try {
+        const auto dmd = common_get_device_memory_data(
+            path_model,
+            mparams,
+            cparams,
+            devs,
+            hp_ngl,
+            hp_nct,
+            hp_nex,
+            log_level,
+            memory_override,
+            print_memory_breakdown);
+
+        out.clear();
+        device_names.clear();
+        out.reserve(dmd.size());
+        device_names.reserve(dmd.size());
+
+        bool synthetic_name_mode = false;
+        if (memory_override != nullptr && !devs.empty()) {
+            ggml_backend_dev_t cpu_dev = ggml_backend_dev_by_type(GGML_BACKEND_DEVICE_TYPE_CPU);
+            if (cpu_dev != nullptr) {
+                synthetic_name_mode = true;
+                for (const auto & dev : devs) {
+                    if (dev != cpu_dev) {
+                        synthetic_name_mode = false;
+                        break;
+                    }
+                }
+            }
+        }
+
+        for (size_t i = 0; i < devs.size(); ++i) {
+            common_fit_memory_data row;
+            row.total = dmd[i].total;
+            row.free = dmd[i].free;
+            row.model = dmd[i].mb.model;
+            row.context = dmd[i].mb.context;
+            row.compute = dmd[i].mb.compute;
+            out.push_back(row);
+
+            if (synthetic_name_mode) {
+                device_names.push_back("Synthetic GPU " + std::to_string(i));
+            } else {
+                device_names.push_back(std::string(ggml_backend_dev_name(devs[i])) + " (" + ggml_backend_dev_description(devs[i]) + ")");
+            }
+        }
+
+        if (!dmd.empty()) {
+            common_fit_memory_data host;
+            host.total = dmd.back().total;
+            host.free = dmd.back().free;
+            host.model = dmd.back().mb.model;
+            host.context = dmd.back().mb.context;
+            host.compute = dmd.back().mb.compute;
+            out.push_back(host);
+            device_names.push_back("Host");
+        }
+
+        return true;
+    } catch (const std::exception & e) {
+        error = e.what();
+        return false;
+    } catch (...) {
+        error = "unknown_exception";
+        return false;
+    }
+}
